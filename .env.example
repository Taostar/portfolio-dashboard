# --- Backend ---
EXTERNAL_API_URL=https://your-external-api.example.com
# Must be valid JSON because CORS_ORIGINS is list[str] in pydantic-settings
CORS_ORIGINS=["https://app.yourdomain.com"]

# --- Frontend (build-time only — baked into the image; changing requires a rebuild) ---
VITE_API_URL=https://api.yourdomain.com/api/v1

# --- Cloudflare Tunnel ---
# From Cloudflare Zero Trust dashboard > Networks > Tunnels > [tunnel] > "Install and run a connector"
# Use the token-only value, not the full docker run command.
TUNNEL_TOKEN=
